# Django
DJANGO_DEBUG=False
DJANGO_SECRET_KEY=troque-por-uma-chave-segura
DJANGO_ALLOWED_HOSTS=seudominio.onrender.com,seudominio.com,www.seudominio.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://seudominio.onrender.com,https://seudominio.com,https://www.seudominio.com
DJANGO_ADMIN_URL=admin-seguro/
DJANGO_TIME_ZONE=America/Sao_Paulo
DJANGO_LOG_LEVEL=INFO

# Render automatically provides RENDER_EXTERNAL_HOSTNAME.
# If it is present, settings.py adds it to ALLOWED_HOSTS and CSRF_TRUSTED_ORIGINS.

# Database
# Prefer DATABASE_URL on Render/Neon/Supabase. It overrides the DB_* variables below.
DATABASE_URL=postgresql://usuario:senha@host:5432/banco
DB_SSL_REQUIRE=False

DB_ENGINE=django.db.backends.postgresql
DB_NAME=KeaBase
DB_USER=postgres
DB_PASSWORD=troque-esta-senha
DB_HOST=localhost
DB_PORT=5432
DB_CONN_MAX_AGE=60

# Security
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=False
DJANGO_SECURE_HSTS_PRELOAD=False
DJANGO_USE_X_FORWARDED_HOST=True
DJANGO_DATA_UPLOAD_MAX_MEMORY_SIZE=10485760
DJANGO_FILE_UPLOAD_MAX_MEMORY_SIZE=5242880

# Media/uploads storage
# local works on Render Free, but files are ephemeral and can disappear after redeploy/restart.
# Use s3 for persistent uploads with AWS S3, Cloudflare R2, Supabase Storage or MinIO.
DJANGO_MEDIA_STORAGE=local
AWS_STORAGE_BUCKET_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_REGION_NAME=
AWS_S3_ENDPOINT_URL=
AWS_S3_CUSTOM_DOMAIN=
AWS_LOCATION=media
AWS_QUERYSTRING_AUTH=False
AWS_S3_CACHE_CONTROL=max-age=86400

# Gunicorn
WEB_CONCURRENCY=2
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=120
